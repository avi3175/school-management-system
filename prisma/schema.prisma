generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role

  imageUrl  String?
  imageId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student?
}

// # 🏫 CLASS MODEL
model Class {
  id        String   @id @default(uuid())
  name      String   // e.g. "Class 10"
  level     Int      // e.g. 10

  sections  Section[]
  students  Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// # 🏫 SECTION MODEL
model Section {
  id        String   @id @default(uuid())
  name      String   // A, B, C

  classId   String
  class     Class    @relation(fields: [classId], references: [id])

  students  Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}














// # 🎓 STUDENT MODEL
model Student {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  classId   String?
  class     Class?   @relation(fields: [classId], references: [id])

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])

  roll      Int

  parentName  String?
  parentPhone String?

  dateOfBirth DateTime?
  gender      String?
  address     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}














enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}