generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role

  imageUrl  String?
  imageId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student?
  teacher   Teacher? 
  parent    Parent?
}

// # 🏫 CLASS MODEL
model Class {
  id        String   @id @default(uuid())
  name      String   // e.g. "Class 10"
  level     Int      // e.g. 10

  sections  Section[]
  students  Student[]

  exams     Exam[]      // ✅ Add this
  teachers  Teacher[]   // ✅ Add

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// # 🏫 SECTION MODEL
model Section {
  id        String   @id @default(uuid())
  name      String   // A, B, C

  classId   String
  class     Class    @relation(fields: [classId], references: [id])

  students  Student[]
  teachers  Teacher[]   // ✅ Add

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}














// # 🎓 STUDENT MODEL
// # 🎓 STUDENT MODEL
model Student {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  classId   String?
  class     Class?   @relation(fields: [classId], references: [id])

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])

  roll      Int

  parentName  String?
  parentPhone String?

  dateOfBirth DateTime?
  gender      String?
  address     String?

  attendance  Attendance[]   // ✅ Add this
  results     Result[]      // ✅ Add this
  parents     Parent[]     // ✅ Add

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}







// # 👨‍🏫 TEACHER MODEL
// Update Teacher model
model Teacher {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  designation String?
  department  String?
  phone       String?
  address     String?
  gender      String?
  dateOfBirth DateTime?

  classId     String?
  class       Class?    @relation(fields: [classId], references: [id])
  sectionId   String?
  section     Section?  @relation(fields: [sectionId], references: [id])
  subjects    Subject[] // ✅ Add this — Teacher can teach multiple subjects

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}





// # 👨‍👩‍👧 PARENT MODEL
// # 👨‍👩‍👧 PARENT MODEL
model Parent {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  occupation        String?
  phone             String?
  address           String?
  relationToStudent String?
  studentId         String?    // ✅ Add
  student           Student?   @relation(fields: [studentId], references: [id])  // ✅ Add

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}






// # 📚 SUBJECT MODEL
model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  description String?

  exams     Exam[]      // ✅ add this
  teachers  Teacher[]   // ✅ Add
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}






// # ✅ ATTENDANCE MODEL
model Attendance {
  id        String   @id @default(uuid())
  date      DateTime @default(now())

  studentId String
  student   Student  @relation(fields: [studentId], references: [id])

  status    AttendanceStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}








// # 📊 RESULT MODEL
model Result {
  id        String   @id @default(uuid())

  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])

  studentId String
  student   Student  @relation(fields: [studentId], references: [id])

  marksObtained Int
  grade         String?
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}











// # 📝 EXAM MODEL
model Exam {
  id        String   @id @default(uuid())
  name      String
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  date      DateTime
  totalMarks Int
  passingMarks Int

  results   Result[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}













enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}